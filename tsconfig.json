{
  "//": "Type-checks the plain-JS sources via JSDoc. No build step: noEmit is on, nothing is compiled or shipped. Run with `npm run typecheck` (tsc --noEmit).",
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020"],
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "types": ["node"],

    "allowJs": true,
    "checkJs": true,
    "noEmit": true,

    "strict": true,
    "useUnknownInCatchVariables": false,

    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/**/*.js", "test/**/*.js", "tests.js", "validate.js"],
  "exclude": ["node_modules"]
}
